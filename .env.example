# Variables consumed by docker-compose.prod.yml.
# In staging/production this file is generated by the deploy pipeline on the EC2;
# for a local run, copy it to .env and adjust the values:
#   cp .env.example .env
#   docker compose -f docker-compose.prod.yml --env-file .env up -d

# GHCR image coordinates (repository must be lowercase).
# For local testing you can build and tag the images yourself instead of pulling.
IMAGE_REPO=eberty/controle-de-logistica
IMAGE_TAG=prod

ASPNETCORE_ENVIRONMENT=Production

# Npgsql connection string. Must start with "Host=".
# Production uses the RDS endpoint; locally, point to any reachable PostgreSQL
# (host.docker.internal reaches a Postgres running on your machine).
DB_CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=asset_management;Username=asset;Password=asset_local_dev

# Frontend origin allowed by the backend CORS policy (AllowedOrigins__0).
ALLOWED_ORIGIN=http://localhost

# Hostnames routed by the nginx proxy (no scheme). Locally, browsers resolve
# *.localhost to 127.0.0.1, so these defaults work out of the box.
FRONTEND_HOST=localhost
API_HOST=api.localhost

# S3 photo storage (see docs/AWS_S3_SETUP.md).
# Leave AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY empty to use the default AWS
# credential chain (e.g. an EC2 instance role). AWS_S3_KEY_PREFIX is optional.
AWS_REGION=us-east-2
AWS_S3_BUCKET_NAME=bucket-example
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_KEY_PREFIX=
